<?xml version="1.0" encoding="utf-8"?>
<!--
  Scoped to this directory (NuGet walks up from the restoring project and uses
  the nearest nuget.config it finds). This runner references a real published
  community package (Vouchfx.Community.JsonRpc) alongside source
  ProjectReferences into .vouchfx-src, so restore is pinned to nuget.org only —
  clearing inherited sources means a stray corporate/offline feed on the
  machine running this sample can never silently supply (or shadow) a package.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
